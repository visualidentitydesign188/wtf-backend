# Server port (default: 3000)
PORT=3000

# Redis URL (default: redis://localhost:6379)
# Required for WebSocket rooms and pub/sub
REDIS_URL=redis://localhost:6379

# Socket.IO CORS (comma-separated list of allowed origins)
# Example: WTF_SOCKETIO_CORS_ORIGINS="https://allthingswtf.com,https://staging.allthingswtf.com"
WTF_SOCKETIO_CORS_ORIGINS=https://allthingswtf.com
